{
  "name": "zhengtu",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "description": "政途人生 v3.0 — 仕途模拟游戏",
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,json}' 'scripts/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,json}' 'scripts/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "validate:config": "tsx scripts/validate-config.ts",
    "ci": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test -- --coverage && pnpm validate:config && pnpm build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/ui": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-solid": "^0.14.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^3.0.0",
    "zod": "^3.24.0"
  }
}
